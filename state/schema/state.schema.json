{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/state.schema.json",
  "title": "Agent Collaboration State Index",
  "type": "object",
  "required": [
    "project",
    "context_version",
    "created",
    "last_updated",
    "updated_by",
    "tasks",
    "decisions",
    "open_questions",
    "recent_changes"
  ],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1
    },
    "context_version": {
      "type": "integer",
      "minimum": 1
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string",
      "minLength": 1
    },
    "updated_from_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "mode",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^task-[0-9]+$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": [
              "split",
              "compete",
              "collab"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "not_started",
              "in_progress",
              "submitted",
              "blocked",
              "done"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "text",
          "scope"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "enum": [
              "global",
              "assignment"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recent_changes": {
      "type": "array",
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": [
          "timestamp",
          "author",
          "summary"
        ],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "author": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
